# ─────────────────────────────────────────────────────────────────────────────
#  Craftly — environment variables
#  Copy this file to `.env.local` and fill in real values for local dev.
#  Never commit `.env.local`, `.env`, or any file with real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Craftly
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Postgres 16 via docker-compose (see docker-compose.yml). User/pass are local-only.
DATABASE_URL=postgresql://craftly:craftly_local_dev@localhost:5432/craftly?schema=public

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth.js v5 ──────────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Resend (transactional email + magic-link auth) ──────────────────────────
RESEND_API_KEY=
EMAIL_FROM="Craftly <hello@example.com>"

# ─── Encryption (AES-256-GCM, for API key storage) ───────────────────────────
# Generate with:  openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Paddle (Merchant of Record) — Phase 4 ───────────────────────────────────
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRO_PRICE_ID=
PADDLE_MAX_PRICE_ID=
PADDLE_PRO_ANNUAL_PRICE_ID=
PADDLE_MAX_ANNUAL_PRICE_ID=

# ─── AI providers — Phase 5 ──────────────────────────────────────────────────
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
# Set MOCK_AI=true to bypass real providers and return deterministic mock
# responses — useful for local dev without burning API calls.
MOCK_AI=

# ─── Contact form forwarding ─────────────────────────────────────────────────
# Where /api/contact submissions are forwarded. Falls back to hello@craftly.app
# if unset; emits to terminal in dev when RESEND_API_KEY is absent.
CONTACT_INBOX=

# ─── Monitoring — Phase 8 ────────────────────────────────────────────────────
# Sentry: install with `pnpm add @sentry/nextjs`, then set DSN. lib/log.ts
# lazy-imports the SDK so it's a no-op when either is missing.
SENTRY_DSN=

# Plausible Analytics — privacy-friendly, no cookies. Mounts the script only
# when domain is set. Override the script src for self-hosted instances.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_PLAUSIBLE_SRC=

# ─── Postgres backups (dev) ──────────────────────────────────────────────────
# Used by `pnpm db:backup` — override only if you renamed the container or DB.
DB_BACKUP_CONTAINER=
POSTGRES_USER=
POSTGRES_DB=

# ─── Lighthouse audit runner ─────────────────────────────────────────────────
# Override the base URL or preset for `pnpm lh`. Defaults: http://localhost:3000, desktop.
LH_BASE_URL=
LH_PRESET=
